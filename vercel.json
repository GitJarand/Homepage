{
  "buildCommand": "vite build && npx esbuild server/vercel-handler.ts --bundle --packages=external --platform=node --format=esm --outfile=api/server.js",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/server" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
